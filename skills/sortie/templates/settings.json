{
  "statusLine": {
    "type": "command",
    "command": "bash <SORTIE_SCRIPTS>/sortie-statusline.sh"
  },
  "permissions": {
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push *--force*)",
      "Bash(git push *-f *)",
      "Bash(git push*origin main*)",
      "Bash(git push*origin master*)",
      "Bash(git push*origin dev*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git branch --delete:*)",
      "Bash(git clean:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout -- :*)",
      "Bash(git restore:*)",
      "Bash(rm:*)",
      "Bash(rm )",
      "Bash(rmdir:*)",
      "Bash(unlink:*)",
      "Bash(trash:*)",
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)"
    ],
    "allow": [
      "Bash(git push -u origin <BRANCH-NAME>)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(bun:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ]
  }
}
